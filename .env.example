# ===========================================
# Farmhelp - Combined Environment Reference
# ===========================================
# This project uses separate .env files per app.
# Copy the relevant section into:
#   - backend/.env
#   - frontend/.env
#   - smart-contracts/.env
# ===========================================

# ---------- BACKEND (backend/.env) ----------
# PORT=5000
# NODE_ENV=development
# MONGO_URL=mongodb://localhost:27017/farmhelp
# JWT_SECRET=your-super-secret-jwt-key-change-in-production
# JWT_EXPIRES_IN=7d
# REFRESH_SECRET=your-refresh-token-secret-change-in-production
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# OPENCAGE_API_KEY=your_opencage_api_key
# HEDERA_NETWORK=testnet
# HEDERA_OPERATOR_ID=0.0.xxxxx
# HEDERA_OPERATOR_PRIVATE_KEY=your_hedera_operator_private_key_hex
# CONTRACT_ADDRESS=0x...
# RPC_URL=https://testnet.hashio.io/api/v1/rpc
# HEDERA_RPC_URL=https://testnet.hashio.io/api/v1/rpc
# PRIVATE_KEY=your_evm_private_key_hex_no_0x
# ADMIN_PRIVATE_KEY=your_admin_private_key_hex_no_0x

# ---------- FRONTEND (frontend/.env) ----------
# VITE_API_URL=http://localhost:5000
# VITE_APP_BACKEND_URL=http://localhost:5000
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ---------- SMART CONTRACTS (smart-contracts/.env) ----------
# PRIVATE_KEY=your_private_key_hex_64_chars
